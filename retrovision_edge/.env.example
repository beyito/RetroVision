# RetroVision Edge Service - Configuración de Variables de Entorno
# Copiar este archivo a .env y rellenar con valores reales

# ===== CONFIGURACIÓN DE VIDEO =====
# Usa una sola fuente por proceso:
# - Webcam local: VIDEO_SOURCE=0
# - Archivo: VIDEO_SOURCE=D:/Videos/prueba.mp4
# - RTSP: VIDEO_SOURCE=rtsp://usuario:password@ip:puerto/ruta
CAMERA_INDEX=0
VIDEO_SOURCE=
FRAME_WIDTH=1280
FRAME_HEIGHT=720
FPS=30
ROI_POLYGON=[[500,350],[900,350],[1100,650],[400,650]]
QUEUE_WAIT_THRESHOLD=5.0

# ===== CONFIGURACIÓN DE BUFFER CIRCULAR =====
# Duración en segundos del buffer circular en RAM
BUFFER_DURATION=30

# ===== CONFIGURACIÓN DE MQTT (Fase Posterior) =====
MQTT_ENABLED=false
MQTT_BROKER_HOST=localhost
MQTT_BROKER_PORT=1883
MQTT_CLIENT_ID=retrovision-edge-01
CAMERA_ID=camera-01

# ===== SINCRONIZACIÓN OPCIONAL CON BACKEND =====
SYNC_CAMERA_CONFIG=false
BACKEND_API_BASE_URL=http://localhost:8000
# Recomendado para producción: credencial propia del edge node
EDGE_NODE_ID=edge-node-01
EDGE_API_KEY=

# Fallback temporal para desarrollo/manual
BACKEND_API_USERNAME=
BACKEND_API_PASSWORD=
BACKEND_API_TOKEN=
BACKEND_API_TIMEOUT=10

# ===== CONFIGURACIÓN DE LOGGING =====
LOG_LEVEL=INFO
LOG_FILE=logs/edge_service.log

# ===== MODO DEBUG =====
DEBUG_MODE=false
